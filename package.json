{
  "name": "ai-work-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first VS Code AI assistant monorepo.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "corepack pnpm -r build",
    "dev:extension": "corepack pnpm --filter ai-work-assistant-extension dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "corepack pnpm -r lint",
    "package:extension": "corepack pnpm --filter ai-work-assistant-extension package",
    "test": "corepack pnpm -r test",
    "typecheck": "corepack pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1"
  },
  "pnpm": {
    "overrides": {
      "cheerio": "1.0.0-rc.12"
    }
  }
}
